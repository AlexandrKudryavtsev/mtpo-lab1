{
    "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "packageManager": "npm",
    "reporters": [
        "html",
        "clear-text",
        "progress"
    ],
    "testRunner": "jest",
    "jest": {
        "config": {
            "testEnvironment": "node"
        }
    },
    "coverageAnalysis": "perTest",
    "thresholds": {
        "high": 80,
        "low": 60,
        "break": 50
    },
    "mutate": [
        "src/algorithms/**/*.js",
        "src/models/**/*.js",
        "src/utils/**/*.js",
        "src/io/jsonLoader.js",
        "!src/**/*.test.js",
        "!src/index.js",
        "!src/io/consoleIO.js"
    ]
}